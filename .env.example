APP_NAME=ASW
APP_ENV=local
APP_KEY=base64:M0OUllc66N9E5MtY5VzOs0v29nIM+2EWbzj+z1V9+5Y=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# Distributed Database Connections — DEV credentials (workshop_2_dev). Local
# development connects to the same 5 real Tailscale-connected servers
# app-server uses, but a separate workshop_2_dev database + user per server
# (not workshop_2_prod) so migrations/seeders here never touch production
# data. See CLAUDE.md's Database Connection Mapping.
# ─────────────────────────────────────────────────────────────────────────────

# eilya — workshop-2 server (MariaDB) | Tailscale: 100.78.124.25
# Tables: report, rescue, image
DB1_HOST=100.78.124.25
DB1_PORT=3306
DB1_DATABASE=workshop_2_dev
DB1_USERNAME=workshop_2_dev
DB1_PASSWORD=workshop_2_dev

# atiqah — linux-mysql (MySQL) | Tailscale: 100.115.237.93
# Tables: category, inventory, slot, section
DB2_HOST=100.115.237.93
DB2_PORT=3306
DB2_DATABASE=workshop_2_dev
DB2_USERNAME=workshop_2_dev
DB2_PASSWORD=workshop_2_dev

# shafiqah — linux-mysql-2 (MySQL) | Tailscale: 100.123.221.89
# Tables: medical, clinic, vet, vaccination, animal, animal_profile
DB3_HOST=100.123.221.89
DB3_PORT=3306
DB3_DATABASE=workshop_2_dev
DB3_USERNAME=workshop_2_dev
DB3_PASSWORD=workshop_2_dev

# danish — linux-mariadb-2 server (MariaDB) | Tailscale: 100.97.35.29
# Tables: booking, transaction, adoption, visit_list, animal_booking
DB4_HOST=100.97.35.29
DB4_PORT=3306
DB4_DATABASE=workshop_2_dev
DB4_USERNAME=workshop_2_dev
DB4_PASSWORD=workshop_2_dev

# taufiq — workshop-postgres server (PostgreSQL) | Tailscale: 100.113.234.24
# Tables: users, roles, permissions, adopter_profile, audit_log
DB5_HOST=100.113.234.24
DB5_PORT=5432
DB5_DATABASE=workshop_2_dev
DB5_USERNAME=workshop_2_dev
DB5_PASSWORD=workshop_2_dev

# ─────────────────────────────────────────────────────────────────────────────

TOYYIBPAY_KEY=
TOYYIBPAY_CATEGORY=
# Use https://dev.toyyibpay.com for sandbox, https://toyyibpay.com for production
TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=cloudinary
QUEUE_CONNECTION=database

# Cloudinary Configuration (for distributed image storage)
# Get these from https://cloudinary.com/console
# ALL TEAM MEMBERS SHOULD USE THE SAME CLOUDINARY CREDENTIALS
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_NOTIFICATION_URL=

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# db:backup emails here on failure/degraded — see docs/10-backups.md.
BACKUP_ALERT_EMAIL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
