APP_NAME=ASW
APP_ENV=testing
APP_KEY=base64:M0OUllc66N9E5MtY5VzOs0v29nIM+2EWbzj+z1V9+5Y=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# Default connection — a PERSISTENT sqlite file, not :memory:.
# The migrations ledger lives on this connection. With :memory: the ledger
# vanishes between boots and `migrate` re-creates everything every run.
# Run `php artisan migrate:fresh --env=testing --force` once, out of band.
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=database/testing.sqlite

# ─────────────────────────────────────────────────────────────────────────────
# Distributed Database Connections — TEST databases on the same 4 Tailscale
# servers documented in CLAUDE.md. Database name is workshop_2_test — NEVER
# point this at workshop_2. See docs/ or the test-plan Phase 0 for the
# provisioning script that creates these databases and the workshop_2 user.
# ─────────────────────────────────────────────────────────────────────────────

# reporting — workshop-2 (MariaDB) | Tailscale: 100.78.124.25
DB1_HOST=100.78.124.25
DB1_PORT=3306
DB1_DATABASE=workshop_2_test
DB1_USERNAME=workshop_2
DB1_PASSWORD=workshop_2

# shelter — linux-mysql (MySQL) | Tailscale: 100.115.237.93
DB2_HOST=100.115.237.93
DB2_PORT=3306
DB2_DATABASE=workshop_2_test
DB2_USERNAME=workshop_2
DB2_PASSWORD=workshop_2

# animals — linux-mysql-2 (MySQL) | Tailscale: 100.123.221.89
DB3_HOST=100.123.221.89
DB3_PORT=3306
DB3_DATABASE=workshop_2_test
DB3_USERNAME=workshop_2
DB3_PASSWORD=workshop_2

# booking — linux-mariadb-2 (MariaDB) | Tailscale: 100.97.35.29
DB4_HOST=100.97.35.29
DB4_PORT=3306
DB4_DATABASE=workshop_2_test
DB4_USERNAME=workshop_2
DB4_PASSWORD=workshop_2

# users — workshop-postgres (PostgreSQL) | Tailscale: 100.113.234.24
DB5_HOST=100.113.234.24
DB5_PORT=5432
DB5_DATABASE=workshop_2_test
DB5_USERNAME=workshop_2
DB5_PASSWORD=workshop_2

# ─────────────────────────────────────────────────────────────────────────────

# Fake key/category — no test should ever reach the real ToyyibPay sandbox.
# Feature tests must Http::fake() every ToyyibPay call.
TOYYIBPAY_KEY=test-key
TOYYIBPAY_CATEGORY=test-cat
TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=sync

# Local disk, not cloudinary — seeders/uploads must not make live Cloudinary
# network calls during tests. phpunit.xml does not override this, so it must
# be set here.
FILESYSTEM_DISK=local
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_NOTIFICATION_URL=

CACHE_STORE=array

MAIL_MAILER=array

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
