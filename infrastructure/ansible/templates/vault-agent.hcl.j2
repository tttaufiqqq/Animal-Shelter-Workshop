{# This Vault v2.0.3 install has no CLI `-exec` flag (confirmed live —
   "flag provided but not defined: -exec" crashed php-fpm's first supervised
   start; php-fpm.service.d/vault-agent-override.conf was removed and the
   process recovered from .env.bak before this template existed). The exec
   command has to live in the config file's own `exec` stanza instead, so one
   rendered copy of this template exists per distinct command — see
   playbooks/tasks/vault-agent.yml, which renders agent-fpm.hcl,
   agent-migrate.hcl, and agent-seed.hcl from it. Only the env_template block
   below is wrapped in {% raw %} — Vault's own template syntax
   (`{{ .Data.data.x }}`) uses the same {{ }} delimiters Jinja does, but
   vault{}/auto_auth{}/sink{} are plain HCL with no {{ }} of their own, so the
   sink path can be a real Jinja variable. It must be — php-fpm's persistent
   config uses systemd's RuntimeDirectory (/run/vault-agent, root-owned,
   correct for php-fpm which also runs as root), but migrate/seed run as
   become_user: taufiq and can't write into a root-owned /run dir (hit this
   live: "permission denied" on /run/vault-agent/token.tmp), so they need
   their own sink path taufiq actually owns. #}
vault {
  address = "http://100.112.41.113:8200"
}

# Auto-auth via the asw-app-server-agent AppRole (bound to the same read-only
# asw-deploy policy as the CLI deploy role, but with a periodic token instead
# of a 15m/30m one — this agent is long-running, the deploy role isn't). See
# oracle-db-learning-proxmox/docs/11-vault-approle-app-integration/.
auto_auth {
  method "approle" {
    mount_path = "auth/approle"
    config = {
      role_id_file_path                   = "/etc/vault-agent/role_id"
      secret_id_file_path                 = "/etc/vault-agent/secret_id"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "{{ vault_agent_sink_path }}"
    }
  }
}

{% raw %}
env_template "APP_KEY" {
  contents = "{{ with secret \"secret/data/animal-shelter-workshop\" }}{{ .Data.data.app_key }}{{ end }}"
}

# DB1-5_PASSWORD all render the exact same secret field (db_password) — one
# app-level credential shared by all 5 connections, see env-app.j2. Confirmed
# live: with byte-identical `contents` strings, Vault Agent only delivered
# the value to ONE of the 5 (the last-declared, DB5_PASSWORD) — the other 4
# showed up as `(unset)` in the actual worker process (checked directly via
# a temporary debug script hit over HTTP), even though config/database.php,
# connectivity, and the credential itself were all otherwise fine. Vault
# Agent appears to dedupe env_template rendering by the literal contents
# string. Fix: an inert per-variable Go-template comment
# ({{/* DBn_PASSWORD */}}, renders as nothing) makes each template's source
# text unique without changing the rendered value, which is enough to stop
# the dedup from colliding them.
env_template "DB1_PASSWORD" {
  contents = "{{ with secret \"secret/data/animal-shelter-workshop\" }}{{ .Data.data.db_password }}{{ end }}{{/* DB1_PASSWORD */}}"
}

env_template "DB2_PASSWORD" {
  contents = "{{ with secret \"secret/data/animal-shelter-workshop\" }}{{ .Data.data.db_password }}{{ end }}{{/* DB2_PASSWORD */}}"
}

