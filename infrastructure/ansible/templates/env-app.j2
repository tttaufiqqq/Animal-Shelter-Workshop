APP_NAME="Animal Shelter Workshop"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL={{ app_url | default('http://' + ansible_host) }}

LOG_CHANNEL=stack
LOG_LEVEL=error

# Default connection — PostgreSQL (always available, hosts migrations table)
DB_CONNECTION=users

# eilya — linux-mariadb (MariaDB, Stray Reporting)
DB1_HOST=linux-mariadb
DB1_PORT=3306
DB1_DATABASE=workshop_2
DB1_USERNAME=workshop_2
DB1_PASSWORD=workshop_2

# atiqah — linux-mysql (MySQL, Shelter Management)
DB2_HOST=linux-mysql
DB2_PORT=3306
DB2_DATABASE=workshop_2
DB2_USERNAME=workshop_2
DB2_PASSWORD=workshop_2

# shafiqah — linux-mysql (MySQL, Stray Animal)
DB3_HOST=linux-mysql
DB3_PORT=3306
DB3_DATABASE=workshop_2
DB3_USERNAME=workshop_2
DB3_PASSWORD=workshop_2

# danish — linux-mariadb (MariaDB, Booking & Adoption)
DB4_HOST=linux-mariadb
DB4_PORT=3306
DB4_DATABASE=workshop_2
DB4_USERNAME=workshop_2
DB4_PASSWORD=workshop_2

# taufiq — linux-postgres (PostgreSQL, Users)
DB5_HOST=linux-postgres
DB5_PORT=5432
DB5_DATABASE=workshop_2
DB5_USERNAME=workshop_2
DB5_PASSWORD=workshop_2

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Cloudinary — fill in after provisioning
CLOUDINARY_URL={{ cloudinary_url | default('cloudinary://api_key:api_secret@cloud_name') }}
CLOUDINARY_CLOUD_NAME={{ cloudinary_cloud_name | default('') }}
CLOUDINARY_API_KEY={{ cloudinary_api_key | default('') }}
CLOUDINARY_API_SECRET={{ cloudinary_api_secret | default('') }}

# ToyyibPay — fill in after provisioning with the same sandbox key/category
# used in local dev (config/toyyibpay.php reads TOYYIBPAY_KEY / TOYYIBPAY_CATEGORY;
# this project has no live merchant account — dev and prod both stay on sandbox).
TOYYIBPAY_KEY={{ toyyibpay_key | default('') }}
TOYYIBPAY_CATEGORY={{ toyyibpay_category | default('') }}
TOYYIBPAY_BASE_URL={{ toyyibpay_base_url | default('https://dev.toyyibpay.com') }}
