{# vault_agent_enabled (group_vars/all.yml): blank every asw_secrets field
   below instead of rendering it, so the plaintext value never lands in this
   file (or, via config:cache, in bootstrap/cache/config.php) — Vault Agent
   injects it straight into the process env instead. See
   playbooks/tasks/vault-agent.yml and oracle-db-learning-proxmox/docs/
   11-vault-approle-app-integration/ for the full design. #}
{% macro secret(value) -%}
{{ '' if vault_agent_enabled else value }}
{%- endmacro %}
APP_NAME="Animal Shelter Workshop"
APP_ENV=production
APP_KEY={{ secret(asw_secrets.app_key) }}
APP_DEBUG=false
APP_URL=https://{{ app_domain }}

LOG_CHANNEL=stack
LOG_LEVEL=error
# Rotating daily files (config/logging.php's own 14-day default retention),
# not the 'single' channel LOG_CHANNEL=stack falls back to when LOG_STACK is
# unset — a single unbounded storage/logs/laravel.log file never gets
# trimmed on its own.
LOG_STACK=daily

# Secure/encrypted session cookie — nginx terminates real TLS on :443 (see
# templates/nginx-app.conf.j2 / the app-server.yml TLS section), so the
# session cookie should never be sent over plain HTTP.
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true

# Default connection — PostgreSQL (always available, hosts migrations table)
DB_CONNECTION=users

# All 5 connections share one app-level credential (asw_secrets.db_password,
# from Vault) — was hardcoded here as the literal "workshop_2", duplicated a
# second time in each linux-{mysql,mariadb,postgres}.yml play var. One value
# now, sourced once, in group_vars/all.yml.

# eilya — linux-mariadb (MariaDB, Stray Reporting)
DB1_HOST=linux-mariadb
DB1_PORT=3306
DB1_DATABASE=workshop_2
DB1_USERNAME=workshop_2
DB1_PASSWORD={{ secret(asw_secrets.db_password) }}

# atiqah — linux-mysql (MySQL, Shelter Management). Migrated off msi
# (100.68.235.121) onto its own dedicated Proxmox VM — see
# docs/03-db-architecture.md.
DB2_HOST=linux-mysql
DB2_PORT=3306
DB2_DATABASE=workshop_2
DB2_USERNAME=workshop_2
DB2_PASSWORD={{ secret(asw_secrets.db_password) }}

# shafiqah — linux-mysql-2 (MySQL, Stray Animal). Migrated off msi onto its
# own dedicated Proxmox CT, separate from DB2's host — see
# docs/03-db-architecture.md.
DB3_HOST=linux-mysql-2
DB3_PORT=3306
DB3_DATABASE=workshop_2
DB3_USERNAME=workshop_2
DB3_PASSWORD={{ secret(asw_secrets.db_password) }}

# danish — linux-mariadb-2 (MariaDB, Booking & Adoption). Split off
# linux-mariadb onto its own dedicated Proxmox CT (2026-07-20) — reporting
# and booking previously shared one physical MariaDB server — see
# docs/03-db-architecture.md.
DB4_HOST=linux-mariadb-2
DB4_PORT=3306
DB4_DATABASE=workshop_2
DB4_USERNAME=workshop_2
DB4_PASSWORD={{ secret(asw_secrets.db_password) }}

# taufiq — linux-postgres (PostgreSQL, Users)
DB5_HOST=linux-postgres
DB5_PORT=5432
DB5_DATABASE=workshop_2
DB5_USERNAME=workshop_2
DB5_PASSWORD={{ secret(asw_secrets.db_password) }}

# file, not database: session/cache must not hard-depend on the users (Postgres)
# connection, or a single DB outage would take down every page's session too —
# this is what the app's own circuit breaker already assumes (it forces
# Cache::store('file') internally regardless of the default store).
CACHE_STORE=file
SESSION_DRIVER=file

# config/filesystems.php defaults FILESYSTEM_DISK to 'local' if unset — this
# was missing from the template entirely (confirmed via a real --check dry
# run against the live .env), which would have silently moved every upload
# off Cloudinary onto local disk on the very first real deploy.
FILESYSTEM_DISK=cloudinary

# sync, not database: grep-confirmed zero Jobs/Mail/Notifications classes and
# no ShouldQueue usage anywhere in app/ — there is no queued work to run, so a
# queue driver that needs its own worker process would just be unused
# complexity. Revisit if queued work is ever added.
QUEUE_CONNECTION=sync

# Cloudinary — sourced from Vault (asw_secrets). TOYYIBPAY_BASE_URL is not a
# secret and stays a literal — see the sandbox note below.
CLOUDINARY_URL={{ secret(asw_secrets.cloudinary_url) }}
CLOUDINARY_CLOUD_NAME={{ secret(asw_secrets.cloudinary_cloud_name) }}
CLOUDINARY_API_KEY={{ secret(asw_secrets.cloudinary_api_key) }}
CLOUDINARY_API_SECRET={{ secret(asw_secrets.cloudinary_api_secret) }}

# ToyyibPay — sourced from Vault (asw_secrets). config/toyyibpay.php reads
# TOYYIBPAY_KEY/TOYYIBPAY_CATEGORY specifically (previously this template
# rendered TOYYIBPAY_SECRET_KEY/TOYYIBPAY_CATEGORY_CODE instead — variable
# names the app never reads, a pre-existing bug fixed alongside this Vault
# change). Base URL stays hardcoded to the sandbox by design, not as an open
# decision — this project has no real users or money moving through it (see
# docs/09-production-hardening.md). Never point this at the live gateway.
TOYYIBPAY_KEY={{ secret(asw_secrets.toyyibpay_key) }}
TOYYIBPAY_CATEGORY={{ secret(asw_secrets.toyyibpay_category) }}
TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com

# Mail — required for password reset to actually deliver (see
# docs/09-production-hardening.md). Without real SMTP credentials this
# silently falls back to Laravel's `log` mailer (config/mail.php's own
# default), which writes the reset email to storage/logs instead of sending
# it. Sourced from Vault (asw_secrets) — was applied by hand directly to the
# live .env and existed nowhere else; see docs/09-production-hardening.md.
MAIL_MAILER=smtp
MAIL_HOST={{ secret(asw_secrets.mail_host) }}
MAIL_PORT={{ secret(asw_secrets.mail_port | default('587')) }}
MAIL_USERNAME={{ secret(asw_secrets.mail_username) }}
MAIL_PASSWORD={{ secret(asw_secrets.mail_password) }}
MAIL_SCHEME={{ secret(asw_secrets.mail_scheme | default('')) }}
MAIL_FROM_ADDRESS={{ secret(asw_secrets.mail_from_address | default('noreply@' + app_domain)) }}
MAIL_FROM_NAME="{{ mail_from_name | default(app_name | default('Animal Shelter Workshop')) }}"
