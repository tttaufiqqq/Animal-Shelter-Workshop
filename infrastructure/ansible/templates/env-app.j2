APP_NAME="Animal Shelter Workshop"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://{{ app_domain }}

LOG_CHANNEL=stack
LOG_LEVEL=error

# Secure/encrypted session cookie — nginx terminates real TLS on :443 (see
# templates/nginx-app.conf.j2 / the app-server.yml TLS section), so the
# session cookie should never be sent over plain HTTP.
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true

# Default connection — PostgreSQL (always available, hosts migrations table)
DB_CONNECTION=users

# eilya — linux-mariadb (MariaDB, Stray Reporting)
DB1_HOST=linux-mariadb
DB1_PORT=3306
DB1_DATABASE=workshop_2
DB1_USERNAME=workshop_2
DB1_PASSWORD=workshop_2

# atiqah — linux-mysql (MySQL, Shelter Management)
DB2_HOST=linux-mysql
DB2_PORT=3306
DB2_DATABASE=workshop_2
DB2_USERNAME=workshop_2
DB2_PASSWORD=workshop_2

# shafiqah — linux-mysql (MySQL, Stray Animal)
DB3_HOST=linux-mysql
DB3_PORT=3306
DB3_DATABASE=workshop_2
DB3_USERNAME=workshop_2
DB3_PASSWORD=workshop_2

# danish — linux-mariadb (MariaDB, Booking & Adoption)
DB4_HOST=linux-mariadb
DB4_PORT=3306
DB4_DATABASE=workshop_2
DB4_USERNAME=workshop_2
DB4_PASSWORD=workshop_2

# taufiq — linux-postgres (PostgreSQL, Users)
DB5_HOST=linux-postgres
DB5_PORT=5432
DB5_DATABASE=workshop_2
DB5_USERNAME=workshop_2
DB5_PASSWORD=workshop_2

# file, not database: session/cache must not hard-depend on the users (Postgres)
# connection, or a single DB outage would take down every page's session too —
# this is what the app's own circuit breaker already assumes (it forces
# Cache::store('file') internally regardless of the default store).
CACHE_STORE=file
SESSION_DRIVER=file

# sync, not database: grep-confirmed zero Jobs/Mail/Notifications classes and
# no ShouldQueue usage anywhere in app/ — there is no queued work to run, so a
# queue driver that needs its own worker process would just be unused
# complexity. Revisit if queued work is ever added.
QUEUE_CONNECTION=sync

# Cloudinary — fill in after provisioning
CLOUDINARY_URL={{ cloudinary_url | default('cloudinary://api_key:api_secret@cloud_name') }}
CLOUDINARY_CLOUD_NAME={{ cloudinary_cloud_name | default('') }}
CLOUDINARY_API_KEY={{ cloudinary_api_key | default('') }}
CLOUDINARY_API_SECRET={{ cloudinary_api_secret | default('') }}

# ToyyibPay — fill in after provisioning
TOYYIBPAY_SECRET_KEY={{ toyyibpay_secret_key | default('') }}
TOYYIBPAY_CATEGORY_CODE={{ toyyibpay_category_code | default('') }}
TOYYIBPAY_BASE_URL={{ toyyibpay_base_url | default('https://dev.toyyibpay.com') }}
TOYYIBPAY_RETURN_URL={{ toyyibpay_return_url | default('') }}
TOYYIBPAY_CALLBACK_URL={{ toyyibpay_callback_url | default('') }}
