server {
    listen 80;
    server_name {{ app_domain }};
    root /home/taufiq/Animal-Shelter-Workshop/public;

{% if tls_cert_exists %}
    # A certificate already exists — send everything else to HTTPS.
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name {{ app_domain }};
    root /home/taufiq/Animal-Shelter-Workshop/public;

    ssl_certificate     /etc/letsencrypt/live/{{ app_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ app_domain }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-XSS-Protection "1; mode=block" always;

    include /etc/nginx/snippets/animal-shelter-locations.conf;
}
{% else %}
    # No certificate yet (first deploy) — serve the app over plain HTTP so
    # certbot's webroot challenge (and the app itself) both work. The block
    # above switches this to a permanent HTTPS redirect and adds the real
    # :443 server block automatically, the moment a certificate exists — see
    # infrastructure/ansible/playbooks/app-server.yml's TLS/HTTPS section.
    include /etc/nginx/snippets/animal-shelter-locations.conf;
}
{% endif %}
