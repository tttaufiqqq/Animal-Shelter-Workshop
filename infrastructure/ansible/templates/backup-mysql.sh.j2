#!/bin/bash
set -euo pipefail

BACKUP_DIR="/var/backups/workshop_2"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
FILE="$BACKUP_DIR/workshop_2_${TIMESTAMP}.sql.gz"

# --routines: stored procedures are NOT included by mysqldump unless asked for
# (unlike triggers, which are on by default) — this app relies on them heavily
# (see CLAUDE.md), so a dump without --routines would be missing the schema
# objects that matter most for a real restore.
mysqldump --single-transaction --routines --triggers workshop_2 | gzip > "$FILE"

# Retention: keep the last 7 daily dumps.
find "$BACKUP_DIR" -name 'workshop_2_*.sql.gz' -mtime +7 -delete
